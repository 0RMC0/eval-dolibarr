# --- Serveur backend NewApp ---
PORT=4000

# Code unique global du backoffice (aussi vérifié côté backend pour protéger reset/import)
BACKOFFICE_CODE=changeme

# --- Connexion à Dolibarr (existingApp) ---
# URL de base de l'API REST Dolibarr
DOLIBARR_URL=http://localhost/dolibarr/api/index.php
# Clé API d'un utilisateur Dolibarr ayant les droits nécessaires
DOLIBARR_API_KEY=your_dolibarr_api_key
# Type de paiement de salaire (dictionnaire c_paiement, ex. 4 = CHQ, 2 = LIQ).
# Module Banque non actif -> aucun compte bancaire requis.
DOLIBARR_PAYMENT_TYPE_ID=4

# --- Base MySQL de Dolibarr (réinitialisation directe [J1 - 1.b]) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=dolibarr
DB_PREFIX=llx_

# --- SQLite (utilisé à partir du J2) ---
SQLITE_PATH=./data/newapp.db

# Origine autorisée pour CORS (frontend Vite)
CORS_ORIGIN=http://localhost:5173
