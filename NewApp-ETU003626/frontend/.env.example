# --- Connexion directe à Dolibarr (existingApp) depuis le navigateur ---
VITE_DOLIBARR_URL=http://localhost/dolibarr/api/index.php
VITE_DOLIBARR_API_KEY=your_dolibarr_api_key

# --- Backend NewApp (reset + import) ---
VITE_BACKEND_URL=http://localhost:4000

# Code backoffice pré-rempli par défaut sur le formulaire (doit correspondre à
# BACKOFFICE_CODE du backend). Le code n'étant pas secret (pré-rempli), c'est voulu.
VITE_BACKOFFICE_CODE=changeme
